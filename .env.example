# Server configuration
LLAMA_SERVER_URL=http://localhost:8082/v1
MCP_SERVER_URL=http://localhost:3000/mcp
MCP_HTTP_PORT=3000

# Paths (relative to project root)
MCP_SERVER_SCRIPT=src/bio_methane_operations_mcp_server_v5.py
VENV_PYTHON=.venv/bin/python

# llama-server / llama.cpp
PORT=8082
LLAMA_SERVER=/usr/local/bin/llama-server-mcp
CTX_SIZE=32768

# Model path (point to your downloaded GGUF)
# MODEL_PATH=$HOME/.lmstudio/models/lmstudio-community/gemma-4-E4B-it-GGUF/gemma-4-E4B-it-Q8_0.gguf

# Hugging Face cache (optional, for RAG embedding models)
# HF_HOME=/path/to/cache
# TRANSFORMERS_CACHE=/path/to/cache/transformers
# SENTENCE_TRANSFORMERS_HOME=/path/to/cache/sentence-transformers
# HF_HUB_OFFLINE=1
